# Шаблон окружения: скопируйте в .env и подставьте реальные значения.
# PowerShell: Copy-Item .env_test .env
# Затем отредактируйте .env (файл .env в репозиторий не коммитить).

# Telegram (python-telegram-bot) — токен от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API (GPT-4o mini и др.)
OPENAI_API_KEY=your_openai_api_key_here

# База данных (SQLAlchemy), пример для PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/promptmaster
# SQLite: файл в каталоге data/ (запускайте приложение из корня проекта)
DATABASE_URL=sqlite:///data/promptmaster.db

# Redis (кэш / лимиты; оставьте пустым, если не используете)
REDIS_URL=redis://localhost:6379/0

# ЮKassa (платежи)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Опционально: публичный URL приложения для вебхуков (FastAPI / nginx)
# WEBHOOK_URL=https://your-domain.example
