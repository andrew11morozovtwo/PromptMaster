# скопируйте в .env: copy-item .env_test .env
# токен сообщества VK (Long Poll, message_new). Не коммитьте реальный токен.
vk_group_token=your_vk_community_token_here

# Для vk_prompt_bot.py — ключ OpenAI (можно задать в .env в корне репозитория PromptMaster).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_MODEL=gpt-4o-mini
